{
  "name": "@mash43/pagefind-hub",
  "version": "0.0.1",
  "type": "module",
  "main": "dist/index.mjs",
  "exports": {
    ".": "./dist/index.mjs",
    "./config": "./dist/config.mjs",
    "./providers": "./dist/providers/index.mjs"
  },
  "bin": {
    "pagefind-hub": "./dist/cli.mjs"
  },
  "scripts": {
    "build": "tsdown",
    "test": "bun test",
    "dev": "bun run src/cli.ts",
    "example": "sh -c 'bun run src/cli.ts examples/${1:-basic}' --",
    "serve": "sh -c 'bun run scripts/serve.ts examples/${1:-basic}/public' --",
    "demo": "sh -c 'bun run example \"$1\" && bun run serve \"$1\"' --"
  },
  "keywords": [
    "pagefind"
  ],
  "author": "mash43",
  "license": "MIT",
  "engines": {
    "node": ">=22.0.0"
  },
  "description": "",
  "dependencies": {
    "jiti": "^2.6.1",
    "pagefind": "^1.5.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "bun-types": "^1.3.11",
    "tsdown": "^0.21.7",
    "typescript": "^6.0.2"
  }
}
