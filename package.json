{
	"name": "@mash43/pagefind-hub",
	"version": "0.1.0",
	"description": "A CLI tool that seamlessly aggregates external content and indexes them alongside your static site's content using Pagefind.",
	"author": "mash43",
	"license": "MIT",
	"homepage": "https://github.com/mashx43/pagefind-hub#readme",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/mashx43/pagefind-hub.git"
	},
	"bugs": {
		"url": "https://github.com/mashx43/pagefind-hub/issues"
	},
	"keywords": [
		"pagefind"
	],
	"publishConfig": {
		"access": "public"
	},
	"type": "module",
	"exports": {
		".": {
			"types": "./dist/index.d.mts",
			"default": "./dist/index.mjs"
		},
		"./providers": {
			"types": "./dist/providers/index.d.mts",
			"default": "./dist/providers/index.mjs"
		},
		"./ui": {
			"types": "./dist/ui/index.d.mts",
			"default": "./dist/ui/index.mjs"
		}
	},
	"bin": {
		"pagefind-hub": "./dist/cli.mjs"
	},
	"files": [
		"dist"
	],
	"engines": {
		"node": ">=22.0.0"
	},
	"scripts": {
		"build": "tsdown",
		"test": "bun test",
		"dev": "bun run src/cli.ts",
		"check": "bun test && biome check && tsc --noEmit --skipLibCheck",
		"biome:fix": "biome check --write",
		"example": "bun run build && cp dist/ui/index.mjs example/public/ui.mjs && cp example/content/* example/public && bun run dist/cli.mjs example",
		"serve": "bun run scripts/serve.ts example/public",
		"demo": "bun run example && bun run serve"
	},
	"dependencies": {
		"jiti": "^2.6.1"
	},
	"peerDependencies": {
		"pagefind": "^1.4.0",
		"rss-parser": "^3.13.0"
	},
	"peerDependenciesMeta": {
		"rss-parser": {
			"optional": true
		}
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.12",
		"@types/node": "^25.6.0",
		"bun-types": "^1.3.13",
		"pagefind": "^1.5.2",
		"rss-parser": "^3.13.0",
		"tsdown": "^0.21.9",
		"typescript": "^6.0.3"
	}
}
